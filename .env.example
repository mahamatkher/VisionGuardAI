# ==============================================================
# VisionGuard AI — Environment Variables
# ==============================================================
# Copy this file to .env and fill in your values.
# The .env file is in .gitignore and NEVER committed to git.
# ==============================================================

# Flask
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
HOST=127.0.0.1
PORT=5000

# Logging
LOG_LEVEL=DEBUG

# Camera
CAMERA_INDEX=0
FRAME_WIDTH=640
FRAME_HEIGHT=480
FRAME_RATE=20

# AI Models
YOLO_MODEL=yolov8n.pt
CONFIDENCE_MIN=0.5

# Tint Detection
TINT_DARKNESS_THRESHOLD=50
